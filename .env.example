# ============================================================
#  Shared (both standalone and Vercel)
# ============================================================
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-BotFather
TELEGRAM_CHAT_ID=123456789

# Which bedroom counts to alert on (comma-separated). studio=0
WANT_BEDROOMS=2,3
# Alert even when bedroom count can't be read off the page (safer)
NOTIFY_ON_UNKNOWN=true
# Watchdog: warn after this many consecutive failed cycles for a site (0 = off)
WATCHDOG_AFTER=3
# Heartbeat: send an "I'm alive" summary at most every N hours (0 = off)
HEARTBEAT_HOURS=24

# ============================================================
#  Standalone runtime only (node cost-rental-bot.mjs)
# ============================================================
POLL_INTERVAL_MIN=15
SEND_STARTUP=true
STATE_FILE=./state.json

# ============================================================
#  Vercel deployment only (set these in the Vercel dashboard)
# ============================================================
# Random string, 16+ chars. Sent as a Bearer token to /api/check.
CRON_SECRET=change-me-to-a-long-random-string
SUPABASE_URL=https://YOURPROJECT.supabase.co
# Service-role key (Project Settings -> API). Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
